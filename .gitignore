# ===== 大文件排除规则（防止2.2GB问题）=====
*.bin              # 二进制文件
*.h5               # HDF5文件
*.pth              # PyTorch模型
*.pt               # PyTorch模型
*.pkl              # Pickle文件
*.pickle           # Pickle文件
*.zip              # 压缩文件
*.tar.gz           # 压缩文件
*.7z               # 压缩文件
*.mp4              # 视频文件
*.avi              # 视频文件
*.mp3              # 音频文件
*.wav              # 音频文件

# ===== 数据集和模型目录 =====
